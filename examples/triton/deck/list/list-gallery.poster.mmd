poster "Deck List Styles"
  columns 2
  gap 28

  cell c_bullets "bullets" :: list
    list
      style bullets
      Market context
      Customer evidence
      Roadmap updates
      Decisions and owners
  end

  cell c_numbered "numbered" :: list
    list
      style numbered
      Discovery
      Build foundation
      Migrate workloads
      Validate operations
  end

  cell c_block "block" :: list
    list
      style block
      Improve reliability
      Expand self-service
      Strengthen governance
      Report outcomes
  end

  cell c_box "box" :: list
    list
      style box
      Onboard the team
      Map stakeholder goals
      Deliver first value
      Review adoption
  end

  cell c_tree "tree" :: list
    list
      style tree
      Commander
        Communications lead
        Operations lead
          Service owners
      Support desk
        Customer liaison
  end

  cell c_chevron "chevron" :: list
    list
      style chevron
      Segment accounts
      Qualify opportunity
      Build proposal
      Handoff to delivery
  end

  cell c_process "process" :: list
    list
      style process
      Intake request
      Assess risk
      Prepare candidate
      Monitor production
  end

  cell c_timeline "timeline" :: list
    list
      style timeline
      July: design feedback
      August: private beta
      September: security review
      October: public preview
  end

  cell c_pyramid "pyramid" :: list
    list
      style pyramid
      Prediction
      Self-service
      Standardized reporting
      Governed foundation
  end

  cell c_columns "columns" :: list
    list
      style columns
      Capability
        Workflow fit
        Integration depth
      Commercials
        Total cost
      Risk
        Compliance posture
  end

  cell c_cycle "cycle" :: list
    list
      style cycle
      Observe signals
      Prioritize bets
      Deliver changes
      Measure impact
  end

  cell c_matrix "matrix" :: list
    list
      style matrix
      Avoid high-impact threats
      Mitigate likely issues
      Transfer exposure
      Accept low-priority risks
  end

  cell c_funnel "funnel" :: list
    list
      style funnel
      Targets
      Discovery meetings
      Business cases
      Closings
  end

  cell c_stepup "stepup" :: list
    list
      style stepup
      Standardize environments
      Automate provisioning
      Shift workloads
      Optimize cost
  end

  cell c_venn "venn" :: list
    list
      style venn
      Customer desirability
      Technical feasibility
      Commercial viability
      Operational readiness
  end
