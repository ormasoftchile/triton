poster "Cell Highlight — Array & Matrix"
    columns 2

    cell sw "Sliding Window"
        array
            cells 1 3 -1 -3 5 3 6 7
            index
            window 1-3
            ptr L -> 1 "L"
            ptr R -> 3 "R"
        caption "window size k=3"
    end

    cell bs "Binary Search"
        array
            cells 2 5 8 11 14 17 20
            index
            highlight 3
            ptr L -> 0 "L"
            ptr M -> 3 "M"
            ptr R -> 6 "R"
        caption "target=11, mid highlighted"
    end

    cell dp "DP Matrix"
        matrix
            title dp table
            row 0 0 0 0
            row 0 1 1 1
            row 0 1 2 2
            row 0 1 2 3
            highlight 2,2 3,3
        caption "current cell highlighted"
    end

    cell mat "Visited Cells"
        matrix
            row 1 2 3
            row 4 5 6
            row 7 8 9
            highlight 0,0 0,2 1,1 2,0 2,2
        caption "spiral-order visited"
    end
