poster "ML Platform — Training & Serving Pipeline"
  columns 3
%% ────────────────────────────────────────────────────────────────────────────
%% CROSS-LINK — options quick-ref
%% ────────────────────────────────────────────────────────────────────────────
%% Header:      poster "Title"  (title optional)
%% Grid:        columns N · rows N · gap N
%% Cell:        cell [id] ["Title"] [span] [:: kind] [@theme t] … end
%% Kinds:       flowchart · flow · timeline · stat · text · <identifier>
%% Link:        link <src> <arrow> <dst> ["label"] [@routing[:WallPair]] [@anim:name] [{ props }]
%% Arrows:      --> · -_-> · -.-> · ==> · -~-> · <--> · <-_-> · <-.-> · <==> · <-~-> · --- · -_- · -.- · === · -~-
%% Styles:      solid -- · dashed -_- · dotted -.- · thick == · wavy -~-
%% Animation:   @anim:march · particle · draw · pulse · glow · comet · stream · flow · colorcycle · none
%% Routing:     @straight · @orthogonal · @bezier · @polyline   (+ :WallPair, e.g. @orthogonal:EW)
%% Props:       { anim:… route:… style:… color:… }   (@ annotations win over { } on conflict)
%% ────────────────────────────────────────────────────────────────────────────

  cell INGEST "Data Ingestion" :: flow
    flowchart LR
      s3[S3 Bucket] --> validator[Validator]
      validator --> registry[Feature Registry]
  end

  cell TRAIN "Training Cluster" :: flow
    flowchart LR
      scheduler[Scheduler] --> gpu[GPU Pool]
      gpu --> checkpointer[Checkpointer]
      checkpointer --> mlflow[MLflow]
  end

  cell SERVE "Model Serving" :: flow
    flowchart LR
      gateway[API Gateway] --> router[Model Router]
      router --> canary[Canary]
      router --> stable[Stable]
  end

  cell MONITOR "Monitoring & Alerts" :: flow
    flowchart LR
      prom[Prometheus] --> grafana[Grafana]
      prom --> alertmgr[Alert Manager]
      alertmgr --> pager[PagerDuty]
  end

  cell CICD "CI/CD" :: flow
    flowchart LR
      gh[GitHub Actions] --> build[Build]
      build --> tests[Tests]
      tests --> deploy[Deploy]
  end

  cell INFRA "Infrastructure" :: flow
    flowchart LR
      terraform[Terraform] --> k8s[Kubernetes]
      k8s --> istio[Istio]
      istio --> vault[Vault]
  end

  link INGEST.registry --> TRAIN.scheduler "triggers training"
  link TRAIN.mlflow --> SERVE.router "promotes model"
  link SERVE.canary -_-> MONITOR.prom "reports metrics" @anim:march
  link SERVE.stable -_-> MONITOR.prom "reports metrics" @anim:march
  link MONITOR.alertmgr --> TRAIN.scheduler "retrains on drift"
  link CICD.deploy --> SERVE.gateway "rolls out"
  link CICD.tests -_-> MONITOR.grafana "posts results" @anim:march
  link INFRA.k8s --> SERVE.stable "hosts"
  link INFRA.vault --> SERVE.gateway "injects secrets"

