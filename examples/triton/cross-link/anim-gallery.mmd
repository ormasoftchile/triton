  link PARTICLE_A.x --> PARTICLE_B.y "particle" { anim: particle }
  link DRAW_A.x --> DRAW_B.y "draw" { anim: draw }
  link PULSE_A.x --> PULSE_B.y "pulse" { anim: pulse }
  link GLOW_A.x --> GLOW_B.y "glow" { anim: glow }
  link COMET_A.x --> COMET_B.y "comet" { anim: comet }
