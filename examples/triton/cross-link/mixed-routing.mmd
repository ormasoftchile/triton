poster "Mixed Routing Styles"
  columns 2
%% ────────────────────────────────────────────────────────────────────────────
%% CROSS-LINK — options quick-ref
%% ────────────────────────────────────────────────────────────────────────────
%% Header:      poster "Title"  (title optional)
%% Grid:        columns N · rows N · gap N
%% Cell:        cell [id] ["Title"] [span] [:: kind] [@theme t] … end
%% Kinds:       flowchart · flow · timeline · stat · text · <identifier>
%% Link:        link <src> <arrow> <dst> ["label"] [@routing[:WallPair]] [@anim:name] [{ props }]
%% Arrows:      --> · -_-> · -.-> · ==> · -~-> · <--> · <-_-> · <-.-> · <==> · <-~-> · --- · -_- · -.- · === · -~-
%% Styles:      solid -- · dashed -_- · dotted -.- · thick == · wavy -~-
%% Animation:   @anim:march · particle · draw · pulse · glow · comet · stream · flow · colorcycle · none
%% Routing:     @straight · @orthogonal · @bezier · @polyline   (+ :WallPair, e.g. @orthogonal:EW)
%% Props:       { anim:… route:… style:… color:… }   (@ annotations win over { } on conflict)
%% ────────────────────────────────────────────────────────────────────────────

  cell AUTH "Authentication" :: flow
    flowchart LR
      login[Login] --> oauth[OAuth]
      oauth --> tokens[Token Store]
      tokens --> session[Session Mgr]
  end

  cell API "API Layer" :: flow
    flowchart LR
      gw[Gateway] --> rate[Rate Limiter]
      rate --> dispatch[Dispatcher]
      dispatch --> cache[Cache]
  end

  cell WORKER "Workers" :: flow
    flowchart LR
      queue[Job Queue] --> exec[Executor]
      exec --> retry[Retry Handler]
      retry --> dlq[Dead Letter Q]
  end

  cell STORE "Data Stores" :: flow
    flowchart LR
      pg[Postgres] --> replica[Read Replica]
      replica --> redis[Redis]
      redis --> s3[S3 Archive]
  end

  link AUTH.session --> API.gw "validates" @orthogonal
  link AUTH.tokens -_-> API.cache "syncs tokens" @bezier @anim:march
  link API.dispatch --> WORKER.queue "enqueues" @straight
  link API.cache -_-> STORE.redis "reads cache" @bezier @anim:march
  link WORKER.exec --> STORE.pg "writes results" @orthogonal
  link WORKER.dlq -_-> STORE.s3 "archives" @anim:march { route: bezier, tension: 0.8 }
  link STORE.replica --> API.cache "feeds cache" @bezier
  link AUTH.oauth -_-> STORE.pg "stores grants" @straight @anim:march

