%% ────────────────────────────────────────────────────────────────────────────
%% ARRAY FLIPPED — demonstration notes
%% ────────────────────────────────────────────────────────────────────────────
%% Shows axis vertical, index bottom reverse, and a middle ... gap exported as cgap.
%% Pointer labels are quoted; numeric target 0 is a logical index, not a slot.
%% Semantic targets clast and cgap address the last live cell and gap directly.
%% head -> 0 and tail -> clast co-locate on cell 34 after reverse numbering.
%% Comments: full-line %% text is stripped before parse; inline/trailing %% is not.
%% ────────────────────────────────────────────────────────────────────────────
  title Symbolic array
  cells 5 8 ... 34
  axis vertical
  index bottom reverse
  ptr head -> 0     "start of the run"
  ptr tail -> clast "last live element"
  ptr probe -> cgap "somewhere in the middle"
