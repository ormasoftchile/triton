poster "Marching Ants — Edge Animation"
  columns 2

  cell FE "Frontend" :: flow
    flowchart LR
      browser[Browser] --> spa[SPA]
  end

  cell BE "Backend" :: flow
    flowchart LR
      api[API] --> service[Service]
  end

  cell CACHE "Cache" :: flow
    flowchart LR
      redis[Redis] --> hot[Hot Keys]
  end

  cell DB "Database" :: flow
    flowchart LR
      pg[(Postgres)] --> replica[(Replica)]
  end

  link FE.browser --> BE.api "requests"
  link BE.service -_-> CACHE.redis "caches" @anim:march
  link BE.api -_-> DB.pg "persists" @anim:march
  link CACHE.redis -.-> DB.pg "invalidates"
