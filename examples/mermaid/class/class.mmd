classDiagram
%% ────────────────────────────────────────────────────────────────────────────
%% CLASS — options quick-ref
%% ────────────────────────────────────────────────────────────────────────────
%% Header:        classDiagram | classDiagram-v2
%% Relationships: <|-- · --|> · <|.. · ..|> · *-- · --* · o-- · --o
%%                <-- · --> · <.. · ..> · -- · ..  (+ "card" on either side · : label)
%% Class body:    class Name { … }  ·  Name : memberText  ·  <<stereotype>>
%% Config:        note text  (discarded)
%% Frontmatter:   --- yaml block --- (before header)
%% Comments:      %% text  (stripped before parse — safe on any line)
%% ────────────────────────────────────────────────────────────────────────────
    class Customer {
        +String id
        +String name
        +String email
        +register()
        +login() bool
    }
    class Order {
        +String orderId
        +Date createdAt
        +float total
        +submit()
        +cancel() bool
    }
    class OrderItem {
        +int quantity
        +float unitPrice
        +float subtotal()
    }
    class Product {
        +String sku
        +String name
        +float price
        +int stock
    }
    class Payment {
        <<interface>>
        +float amount
        +process() bool
        +refund() bool
    }
    class CreditCardPayment {
        +String cardNumber
        +String expiry
        +process() bool
        +refund() bool
    }
    class ShoppingCart {
        +addItem(Product p)
        +removeItem(String sku)
        +checkout() Order
    }
    Customer "1" --> "*" Order : places
    Order *-- OrderItem : contains
    OrderItem --> Product : references
    Payment <|.. CreditCardPayment
    Customer --> ShoppingCart : has
    ShoppingCart --> Order : creates
