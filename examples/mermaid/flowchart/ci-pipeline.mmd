%% ────────────────────────────────────────────────────────────────────────────
%% FLOWCHART — options quick-ref
%% ────────────────────────────────────────────────────────────────────────────
%% Header:      flowchart | graph
%% Directions:  TD · TB · BT · LR · RL
%% Node shapes: [rect] · (rounded) · ((circle)) · ([stadium]) · [[sub]]
%%              [(cyl)] · {{hex}} · {diamond} · [/para/] · [\para-alt\] · >asym]
%% Edges:       --> -_-> -.-> ==> -~->  ·  <--> <-_-> <-.-> <==> <-~->  ·  --- -_- -.- === -~-  ·  --x --o   (+|label|)
%% Styles:      solid -- · dashed -_- · dotted -.- · thick == · wavy -~-
%% Animation:   @anim:march · particle · draw · pulse · glow · comet · stream · flow · colorcycle · none
%% Routing:     @straight · @orthogonal · @bezier · @polyline   (+ :WallPair, e.g. @orthogonal:EW)
%% Chains:      A --> B --> C   (mix operators freely)
%% Blocks:      subgraph id [Label] … end
%% Overlays:    note "txt" at id  ·  legend corner "title" … end
%% Directives:  style id …  ·  classDef name …  ·  class ids name  ·  click id …
%% Frontmatter: --- yaml block --- (before header)
%% Comments:    %% text  (stripped before parse — safe on any line)
%% ────────────────────────────────────────────────────────────────────────────
  commit[Commit Pushed] --> build[Build & Lint]
  build --> test{Tests Pass?}
  test -->|yes| stage([Deploy to Staging])
  test -->|no| notify(Notify Author)
  stage --> approve{Approved?}
  approve -->|yes| prod([Deploy to Production])
  approve -->|no| hold(Hold for Review)
  prod --> live((Live))
