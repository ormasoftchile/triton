architecture-beta
%% Triton architecture-beta showcase: a small edge-to-cloud data platform.
%% Group icon alignment: Triton places icons on explicit compass anchors for groups.
group edge(cloud)[Edge Landing Zone] @iconalign:NW
group platform(cloud)[Core Data Platform] @iconalign:SE
group ops(server)[Operations Console] @iconalign:E

%% Service icon alignment: Triton also supports compass icon anchors on services.
service users(internet)[Branch Users] @iconalign:E
service gateway(server)[API Gateway] in edge @iconalign:W
service collector(server)[Event Collector] in edge @iconalign:S
service stream(server)[Stream Bus] in platform @iconalign:N
service lake(database)[Data Lake] in platform @iconalign:SW
service warehouse(database)[Warehouse] in platform @iconalign:SE
service dashboard(custom)[Ops Dashboard] in ops @iconalign:C
service backup(disk)[Offline Backup] @iconalign:NW

%% Connector matrix: Triton dashed directed links model control-plane requests.
%% Routing control: orthogonal routing plus an EW wall hint keeps ingress horizontal.
users:R -_-> L:gateway @anim:flow @route:orthogonal @straight:EW

%% Connector matrix: Triton wavy directed links model streaming telemetry.
%% Connector animations: @anim uses a named Triton connector animation.
gateway:B -~-> T:collector @anim:stream @route:bezier

%% Connector matrix: Triton dashed bidirectional links model reliable replay acks.
%% Connector animations: @anim wins over the conflicting { anim } property block.
collector:R <-_-> L:stream @anim:march @route:orthogonal @straight:EW 

%% Connector matrix: Triton wavy undirected links model a shared stream-to-lake feed.
%% Connector animations: property-block animation form is supported too.
stream:B -~- T:lake @route:polyline { anim: particle }

%% Mermaid contrast: thick connectors remain available for bulk batch loads.
lake:R ==> L:warehouse @anim:draw @route:straight

%% Mermaid contrast: dotted connectors remain available for low-volume read APIs.
warehouse:R -.-> L:dashboard @anim:glow @bezier:NE

%% Connector matrix: Triton wavy bidirectional links model live operational feedback.
dashboard:L <-~-> T:gateway @anim:comet @polyline:SW

%% Connector matrix: Triton dashed undirected links model an offline backup window.
lake:B -_- T:backup @anim:pulse @route:orthogonal @orthogonal:SN
