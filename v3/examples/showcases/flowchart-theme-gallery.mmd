poster "Flowchart Theme Gallery"
  columns 3

  cell "Default" :: flow @theme default
    flowchart TD
      req([Request]) --> auth{Authed?}
      auth -->|no| deny[Reject]
      auth -->|yes| rate{Rate OK?}
      rate -->|no| wait[Throttle]
      rate -->|yes| proc[Process]
      proc --> cache[(Cache)]
      proc --> db[(Database)]
      proc --> ok([Response])
  end

