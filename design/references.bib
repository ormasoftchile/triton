@book{grammarofgraphics2005,
  author       = {Wilkinson, Leland},
  title        = {The Grammar of Graphics},
  edition      = {2},
  year         = {2005},
  publisher    = {Springer},
  address      = {New York},
  isbn         = {978-0-387-24544-7},
  note         = {Foundational theory decomposing statistical graphics into
                  data, aesthetics, geometry, statistics, scales, coordinates,
                  and facets. Basis for ggplot2 and Vega-Lite.}
}

@article{layeredgrammar2010,
  author       = {Wickham, Hadley},
  title        = {A Layered Grammar of Graphics},
  journal      = {Journal of Computational and Graphical Statistics},
  volume       = {19},
  number       = {1},
  pages        = {3--28},
  year         = {2010},
  doi          = {10.1198/jcgs.2009.07098},
  url          = {https://vita.had.co.nz/papers/layered-grammar.html},
  note         = {Formalizes the Grammar of Graphics as a layered system
                  (data $\to$ aesthetics $\to$ geom $\to$ stat $\to$ coord
                  $\to$ facet). Powers ggplot2.}
}

@inproceedings{vegalite2017,
