poster "System Traceability — Cross-Diagram Traces"

  cell A1: flowchart LR
    SPEC[Auth Spec §4] --> REQ1[REQ-01: Auth < 500ms]
    SPEC --> REQ2[REQ-02: Token expires 24h]

  cell A2: flowchart LR
    SUITE[CI test-suite] --> T1[auth_latency_test]
    SUITE --> T2[token_expiry_test]

  cell B1:B2: classDiagram
    class AuthController {
      +login(): Token
      +validate(): bool
    }
    class TokenService {
      +issue(): Token
      +revoke(): void
    }
    class SessionCache {
      +get(): Session
      +put(): void
    }
    AuthController --> TokenService : issues
    TokenService --> SessionCache : caches

trace "REQ-01 chain" satisfies : A1.REQ1 --> B1.AuthController --> A2.T1
trace "REQ-02 chain" satisfies : A1.REQ2 --> B1.TokenService --> A2.T2
