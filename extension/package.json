{
  "name": "triton-vscode",
  "displayName": "Triton",
  "description": "Live preview for Triton diagrams (and Mermaid) — deterministic SVG, rendered by the Triton compiler.",
  "version": "0.1.25",
  "private": true,
  "publisher": "focus-space",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ormasoftchile/triton.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages"
  ],
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "main": "./dist/extension.cjs",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:triton.openPreview",
    "onCommand:triton.openPreviewToSide",
    "onCommand:triton.exportSvg",
    "onCommand:triton.exportPng",
    "onCommand:triton.exportAs"
  ],
  "contributes": {
    "markdown.markdownItPlugins": true,
    "languages": [
      {
        "id": "triton",
        "aliases": [
          "Triton"
        ],
        "extensions": [
          ".triton"
        ]
      }
    ],
    "commands": [
      {
        "command": "triton.openPreview",
        "title": "Open Preview",
        "icon": {
          "light": "./resources/preview-light.svg",
          "dark": "./resources/preview-dark.svg"
        }
      },
      {
        "command": "triton.openPreviewToSide",
        "title": "Open Preview to the Side",
        "icon": {
          "light": "./resources/preview-side-light.svg",
          "dark": "./resources/preview-side-dark.svg"
        }
      },
      {
        "command": "triton.exportSvg",
        "title": "Export as SVG",
        "category": "Triton",
        "icon": "$(export)"
      },
      {
        "command": "triton.exportPng",
        "title": "Export as PNG",
        "category": "Triton",
        "icon": "$(file-media)"
      },
      {
        "command": "triton.exportAs",
        "title": "Export As…",
        "category": "Triton",
        "icon": "$(save-as)"
      }
    ],
    "submenus": [
      {
        "id": "triton.exportMenu",
        "label": "Triton Export",
        "icon": "$(chevron-down)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "triton.openPreview",
          "when": "resourceLangId == triton || resourceExtname == .triton || resourceExtname == .mmd"
        },
        {
          "command": "triton.openPreviewToSide",
          "when": "resourceLangId == triton || resourceExtname == .triton || resourceExtname == .mmd"
        },
        {
          "command": "triton.exportSvg",
          "when": "resourceLangId == triton || resourceExtname == .triton || resourceExtname == .mmd"
        },
        {
          "command": "triton.exportPng",
          "when": "resourceLangId == triton || resourceExtname == .triton || resourceExtname == .mmd"
        },
        {
          "command": "triton.exportAs",
          "when": "resourceLangId == triton || resourceExtname == .triton || resourceExtname == .mmd"
        }
      ],
      "editor/title": [
        {
          "command": "triton.exportSvg",
          "when": "resourceLangId == triton || resourceExtname == .triton || resourceExtname == .mmd",
          "group": "navigation@1"
        },
        {
          "submenu": "triton.exportMenu",
          "when": "resourceLangId == triton || resourceExtname == .triton || resourceExtname == .mmd",
          "group": "navigation@2"
        },
        {
          "command": "triton.openPreviewToSide",
          "when": "resourceLangId == triton || resourceExtname == .triton || resourceExtname == .mmd",
          "group": "navigation@3"
        },
        {
          "command": "triton.openPreview",
          "when": "resourceLangId == triton || resourceExtname == .triton || resourceExtname == .mmd",
          "group": "navigation@4"
        }
      ],
      "triton.exportMenu": [
        {
          "command": "triton.exportSvg",
          "when": "resourceLangId == triton || resourceExtname == .triton || resourceExtname == .mmd",
          "group": "1_export@1"
        },
        {
          "command": "triton.exportPng",
          "when": "resourceLangId == triton || resourceExtname == .triton || resourceExtname == .mmd",
          "group": "1_export@2"
        },
        {
          "command": "triton.exportAs",
          "when": "resourceLangId == triton || resourceExtname == .triton || resourceExtname == .mmd",
          "group": "1_export@3"
        }
      ],
      "editor/context": [
        {
          "command": "triton.openPreview",
          "when": "resourceLangId == triton || resourceExtname == .triton || resourceExtname == .mmd",
          "group": "navigation"
        },
        {
          "command": "triton.openPreviewToSide",
          "when": "resourceLangId == triton || resourceExtname == .triton || resourceExtname == .mmd",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Triton",
      "properties": {
        "triton.enableMermaid": {
          "type": "boolean",
          "default": false,
          "description": "Passively handle Mermaid content (`.mmd` files and ```mermaid fenced blocks) for automatic preview. Defaults to OFF so Triton never stomps an already-installed Mermaid extension. The explicit 'Triton: Open Preview' command always renders the active file regardless of this setting; `.triton` files and ```triton blocks are always handled."
        },
        "triton.preview.debounceMs": {
          "type": "number",
          "default": 150,
          "minimum": 0,
          "description": "Delay (in milliseconds) after the last edit before the live preview re-renders."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package": "vsce package --no-dependencies",
    "deploy": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.8.3"
  }
}
