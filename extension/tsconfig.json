{
  // Editor / typecheck only — esbuild (see esbuild.mjs) does the actual bundling.
  //
  // NOTE on module resolution: `extension.ts` is bundled by esbuild into a single
  // CommonJS file, and it statically imports the Triton compiler source, which is
  // ESM (the repo root sets `"type": "module"`). Under `NodeNext`, TypeScript would
  // reject that with TS1479 (a CJS module cannot `require` an ESM source via a
  // static import). Because esbuild is the real bundler here, `moduleResolution:
  // "bundler"` is the faithful model: it performs the same NodeNext-style `.js`→`.ts`
  // specifier resolution the compiler graph relies on, without enforcing the
  // CJS/ESM require-interop rule that only matters at Node's runtime boundary —
  // which esbuild has already collapsed away by bundling everything into one file.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["vscode", "node"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"]
}
