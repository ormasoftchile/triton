{
  "name": "triton",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Triton — deterministic, contracts-first diagram compiler (SVG/PNG)",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,js,json,yaml,yml,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,js,json,yaml,yml,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4"
  }
}
