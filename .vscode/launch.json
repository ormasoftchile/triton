{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Triton Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension",
        "--disable-extension=focus-space.deckpilot-triton",
        "--disable-extension=focus-space.deckpilot-mermaid"
      ],
      "outFiles": ["${workspaceFolder}/extension/dist/**/*.cjs"],
      "sourceMaps": true,
      "preLaunchTask": "watch-extension"
    }
  ]
}
