{
  "name": "@timeline-compiler/core",
  "version": "0.1.0",
  "description": "Timeline Compiler core library — pure API for loading, validating, and rendering timeline IR",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/fonts"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "postbuild": "node --input-type=module -e \"import{cpSync}from'node:fs';cpSync('src/fonts','dist/fonts',{recursive:true});\"",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src test",
    "test": "vitest run"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "canvaskit-wasm": "^0.41.1",
    "yaml": "^2.9.0",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
